APP_NAME=AI Diagnostic System
ENV=development
DEBUG=True

# Localhost values - correct for running locally (no Docker).
# When you run via `docker compose up`, docker-compose.yml automatically
# overrides these four to use the db/redis container hostnames instead -
# you do NOT need to change this file when switching between the two.
DATABASE_URL=postgresql+asyncpg://postgres.gukufowgfzcgfalckzld:yGFLd6ilzGjDJs74@aws-1-ap-south-1.pooler.supabase.com:5432/diagnostic_center_db

SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=diagnostic-reports
S3_REGION=ap-south-1
SIGNED_URL_EXPIRY_SECONDS=300

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
